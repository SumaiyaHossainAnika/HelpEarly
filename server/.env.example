# Use this for one shared online PostgreSQL database.
# Put the same DATABASE_URL on every PC that should share accounts, bans, bookings, and chats.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Local database fallback. These are ignored when DATABASE_URL is set.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=1234
DB_NAME=helpearly

# JWT
JWT_SECRET=helpearly_super_secret_jwt_key_2026

# Server
PORT=5000
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# In production, set CLIENT_URL to your deployed frontend URL.
# For multiple allowed frontends, separate them with commas:
# CLIENT_URL=http://localhost:5173,https://your-frontend.vercel.app
