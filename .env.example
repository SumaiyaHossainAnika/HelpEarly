# Database
# Optional shared online database
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=helpearly

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production

# Server
PORT=5000
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# In production, set CLIENT_URL to your deployed frontend URL.
# For multiple allowed frontends, separate them with commas:
# CLIENT_URL=http://localhost:5173,https://your-frontend.vercel.app
